rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // 登入即可讀取（查閱/下載檔案）
      allow read: if request.auth != null;
      // 寫入（上傳/覆蓋/刪除檔案）僅限 S 級或 A 級帳號，比照 Firestore 規則
      allow write: if request.auth != null &&
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.level == 'S'
        || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.level == 'A');
    }
  }
}
